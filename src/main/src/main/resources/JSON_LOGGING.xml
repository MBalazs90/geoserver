<?xml version="1.0" encoding="UTF-8"?>
<Configuration name="JSON_LOGGING" status="fatal" dest="out">
    <Appenders>
        <Console name="stdout" target="SYSTEM_OUT">
            <JsonLayout compact="true" eventEol="true" stacktraceAsString="true"
                        properties="true" includeTimeMillis="true">
                <KeyValuePair key="application" value="geoserver"/>
                <KeyValuePair key="environment" value="ocp-lab"/>
            </JsonLayout>
        </Console>
    </Appenders>
    <Loggers>
        <Logger name="org.geotools" level="warn" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.geotools.factory" level="warn" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.geoserver" level="info" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.geoserver.config" level="info" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.geoserver.security" level="info" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.vfny.geoserver" level="warn" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.springframework" level="error" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Logger name="org.geowebcache" level="error" additivity="false">
            <AppenderRef ref="stdout"/>
        </Logger>
        <Root level="warn">
            <AppenderRef ref="stdout"/>
        </Root>
    </Loggers>
</Configuration>
